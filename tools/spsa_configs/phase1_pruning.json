{
  "_comment": "Phase 1 SPSA config: futility, razor, null-move, LMP, SEE, singular margins.",
  "_prereq": "Each 'name' must match a UCI 'option name ... type spin' in src/search_options.rs",

  "engine": "D:\\chess\\engines\\rarog-phase1-pext-pgo.exe",
  "book":   "D:\\chess\\books\\SuperGM_4mvs.pgn",
  "cutechess": "D:\\chess\\cutechess-cli\\cutechess-cli.exe",

  "hash":          64,
  "concurrency":   7,
  "games_per_iter": 100,
  "max_iterations": 3000,
  "save_interval":  50,

  "params": [
    {
      "name":    "FutilityBase",
      "_note":   "Futility margin base (search.rs:1003: (70 + 20*not_improving) * depth)",
      "default": 70,
      "value":   70,
      "min":     30,
      "max":     150,
      "c":       8
    },
    {
      "name":    "FutilityImproving",
      "_note":   "Futility margin not-improving coefficient (the '20' in the formula)",
      "default": 20,
      "value":   20,
      "min":     0,
      "max":     60,
      "c":       6
    },
    {
      "name":    "RazoringCoeff",
      "_note":   "Razoring margin coefficient (search.rs:1007: 150 * depth)",
      "default": 150,
      "value":   150,
      "min":     60,
      "max":     300,
      "c":       16
    },
    {
      "name":    "NullMoveDepthCoeff",
      "_note":   "Null-move base margin coefficient (search.rs:1012: 12 * depth)",
      "default": 12,
      "value":   12,
      "min":     4,
      "max":     30,
      "c":       3
    },
    {
      "name":    "NullMoveImprovingBonus",
      "_note":   "Null-move improving bonus (search.rs:1012: 24 * improving_i)",
      "default": 24,
      "value":   24,
      "min":     0,
      "max":     60,
      "c":       6
    },
    {
      "name":    "LmpBase",
      "_note":   "LMP prune margin base (search.rs:1182: (90 + 25*not_improving) * depth)",
      "default": 90,
      "value":   90,
      "min":     40,
      "max":     180,
      "c":       12
    },
    {
      "name":    "SeePruningCoeff",
      "_note":   "SEE pruning quiet threshold (search.rs:1195: -80 * depth)",
      "default": 80,
      "value":   80,
      "min":     30,
      "max":     160,
      "c":       10
    },
    {
      "name":    "AspirationDelta",
      "_note":   "Initial aspiration window half-width (search.rs:615: 25 cp)",
      "default": 25,
      "value":   25,
      "min":     10,
      "max":     60,
      "c":       4
    },
    {
      "name":    "SingularBetaMult",
      "_note":   "Singular beta multiplier (search.rs:1215: tt_score - 2*depth)",
      "default": 2,
      "value":   2,
      "min":     1,
      "max":     6,
      "c":       1
    }
  ]
}
