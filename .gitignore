# Generated by Cargo
# will have compiled files and executables
debug/
target/
Cargo.lock
*.profraw
*.profdata

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Editors / OS-local state
.idea/
.vscode/
.vs/
*.user
*.suo
*.swp
*~
.DS_Store
Thumbs.db

# Local environment/configuration
.env
.env.*
*.local
*.local.*

# Testing harness outputs
tools/results/*
!tools/results/.gitkeep
tools/bin/*
!tools/bin/.gitkeep
tools/test_engines/*
!tools/test_engines/.gitkeep
tools/weather-factory/

# Local opening books / third-party chess assets
tools/books/*
!tools/books/.gitkeep
*.rtbw
*.rtbz

# Python caches / virtualenvs
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/

# weather-factory working files (copied here during SPSA runs)
/config.json

# Texel tuning datasets / generated artifacts (large; regenerate via tools/texel)
tools/texel/data/*
!tools/texel/data/.gitkeep
tools/texel/out/
